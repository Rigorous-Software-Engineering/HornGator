       (or (not P16) O16)
       (or (not U23) (not C21))
       (or (not I19) (not O17))
       (or (not A21) (not I4))
       (not G27)
       (= O27 true)
       (not V23)
       (not P25)
       (not S24)
       (not (= (= N22 0) Q1))))
      )
      main@ldv_check_alloc_flags.split
    )
  )
)
(assert
  (forall ( (CHC_COMP_UNUSED Bool) ) 
    (=>
      (and
        main@ldv_check_alloc_flags.split
        true
      )
      false
    )
  )
)

(check-sat)
