     (= G1 (ite N2 L2 M2))
     (= F1 (and P2 O2))
     (= E1 (ite S2 Q2 R2))
     (= H (or (not G5) F5))
     (= G (ite J5 H5 I5))
     (= F (ite M5 K5 L5))
     (= E (ite P5 N5 O5))
     (= D (ite S5 Q5 R5))
     (= C (ite V5 T5 U5))
     (= B (ite Y5 W5 X5))
     (= A (ite B6 Z5 A6))
     (= K1 (ite B2 Z1 A2)))
      )
      realizable
    )
  )
)
(assert
  (forall ( (CHC_COMP_UNUSED Bool) ) 
    (=>
      (and
        realizable
        true
      )
      false
    )
  )
)

(check-sat)
